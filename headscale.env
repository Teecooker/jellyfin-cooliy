HEADSCALE_DOMAIN=headscale.securand.de
CADDY_EMAIL=m.kant.cordeiro@gmail.com
# Server-Einstellungen
HEADSCALE_SERVER_URL=https://headscale.securand.de
HEADSCALE_LISTEN_ADDR=0.0.0.0:8080

# Datenbank (SQLite reicht völlig)
HEADSCALE_DATABASE_TYPE=sqlite3
HEADSCALE_DATABASE_SQLITE_PATH=/data/headscale.db

# Noise-Private-Key (wird automatisch generiert, Pfad angeben)
#HEADSCALE_NOISE_PRIVATE_KEY_PATH=/data/noise_private.key

# IP-Pool für die Clients (Tailscale-Standard)
HEADSCALE_IP_PREFIXES=100.64.0.0/10

# Kein TLS, da Coolify/Caddy das SSL-Terminierung übernimmt
HEADSCALE_TLS_LETSENCRYPT_ENABLED=false
# HEADSCALE_TLS_CERTPATH und HEADSCALE_TLS_KEYPATH bleiben leer

# DERP-Server (für Verbindungen hinter NAT) - optional, erstmal deaktivieren
HEADSCALE_DERP_SERVER_ENABLED=false